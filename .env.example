# Azure AI Foundry project endpoint (for Skills, Toolbox, and Agent APIs)
AZURE_FOUNDRY_ENDPOINT=https://<ai-services-account>.services.ai.azure.com/api/projects/<project-name>

# Azure OpenAI resource (for direct Responses API calls)
AZURE_OPENAI_ENDPOINT=https://<ai-services-account>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Model deployment name (as shown in Azure AI Foundry → Deployments)
AZURE_CHAT_MODEL_DEPLOYMENT=gpt-5.4-mini

# Agent and toolbox names (can be left as defaults)
AGENT_NAME=foundry-harness
TOOLBOX_NAME=harness-toolbox

# Local path to skill SKILL.md files (relative to project root)
SKILLS_DIR=skills

# URL of the local file/shell MCP server (run: python -m local_mcp.server)
LOCAL_MCP_URL=http://127.0.0.1:8765

# External MCP connections (JSON dict: {label: {server_url, connection_id, require_approval}})
# Register connections in Azure AI Foundry portal first, then add them here.
# Example:
# MCP_CONNECTIONS={"github": {"server_url": "https://api.githubcopilot.com/mcp", "connection_id": "my-github-conn", "require_approval": "always"}}
MCP_CONNECTIONS={}

# Set to "true" to interactively approve each MCP tool call at runtime
MCP_REQUIRE_APPROVAL=false

# OpenTelemetry — OTLP/HTTP exporter (leave blank to disable tracing)
# Point at your OTEL collector's HTTP port (default 4318):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://<collector-host>:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# Bearer token for collector authentication (omit if collector is unauthenticated)
OTEL_EXPORTER_OTLP_BEARER_TOKEN=
OTEL_SERVICE_NAME=foundry-harness
# Set to "true" to include prompts and completions as span events (PII risk)
OTEL_CAPTURE_CONTENT=false
# Log level exported to the OTEL collector: DEBUG | INFO | WARNING | ERROR | CRITICAL
OTEL_LOG_LEVEL=INFO
